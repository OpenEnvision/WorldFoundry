{
  "name": "worldfoundry-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "api:check": "python3 scripts/generate-python-api.py --check",
    "api:generate": "python3 scripts/generate-python-api.py",
    "build": "next build --webpack",
    "cli:screenshots": "python3 scripts/capture-cli-screenshots.py",
    "dev": "next dev --hostname 0.0.0.0 --webpack",
    "dev:fast": "WF_DOCS_FAST_CACHE=1 next dev --hostname 0.0.0.0 --webpack",
    "dev:local": "bash scripts/dev-local-ssd.sh dev",
    "mdx:generate": "fumadocs-mdx",
    "models:generate": "python3 scripts/generate-model-recipes.py",
    "prebuild": "npm run mdx:generate && npm run api:generate",
    "predev": "npm run mdx:generate && npm run api:generate",
    "pretypes:check": "npm run api:generate",
    "start": "node scripts/serve-static.mjs",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@orama/orama": "^3.1.18",
    "fumadocs-core": "^16.8.8",
    "fumadocs-mdx": "^15.0.0",
    "fumadocs-ui": "^16.8.8",
    "katex": "^0.17.0",
    "lucide-react": "^1.14.0",
    "mdast-util-gfm-table": "^2.0.0",
    "next": "^16.2.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.13",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  }
}
